    "common.labels.strength_tooltip": {
      "en": "1: Very Weak - Minimal influence\n2: Weak - Small influence\n3: Medium - Moderate influence\n4: Strong - Significant influence\n5: Very Strong - Major influence",
      "es": "1: Muy Débil - Influencia mínima\n2: Débil - Influencia pequeña\n3: Medio - Influencia moderada\n4: Fuerte - Influencia significativa\n5: Muy Fuerte - Influencia mayor",
      "fr": "1: Très Faible - Influence minimale\n2: Faible - Petite influence\n3: Moyen - Influence modérée\n4: Fort - Influence significative\n5: Très Fort - Influence majeure",
      "de": "1: Sehr Schwach - Minimaler Einfluss\n2: Schwach - Geringer Einfluss\n3: Mittel - Mäßiger Einfluss\n4: Stark - Bedeutender Einfluss\n5: Sehr Stark - Großer Einfluss",
      "lt": "1: Labai silpnas - Minimali įtaka\n2: Silpnas - Maža įtaka\n3: Vidutinis - Vidutinė įtaka\n4: Stiprus - Reikšminga įtaka\n5: Labai stiprus - Didelė įtaka",
      "pt": "1: Muito Fraco - Influência mínima\n2: Fraco - Influência pequena\n3: Médio - Influência moderada\n4: Forte - Influência significativa\n5: Muito Forte - Influência maior",
      "it": "1: Molto Debole - Influenza minima\n2: Debole - Influenza ridotta\n3: Medio - Influenza moderata\n4: Forte - Influenza significativa\n5: Molto Forte - Influenza maggiore",
      "no": "1: Veldig Svak - Minimal innflytelse\n2: Svak - Liten innflytelse\n3: Middels - Moderat innflytelse\n4: Sterk - Betydelig innflytelse\n5: Veldig Sterk - Stor innflytelse",
      "el": "1: Πολύ Αδύναμο - Ελάχιστη επιρροή\n2: Αδύναμο - Μικρή επιρροή\n3: Μέτριο - Μέτρια επιρροή\n4: Ισχυρό - Σημαντική επιρροή\n5: Πολύ Ισχυρό - Μεγάλη επιρροή"
    },
    "common.labels.confidence_tooltip": {
      "en": "1: Very Low - Highly uncertain\n2: Low - Uncertain with limited evidence\n3: Medium - Moderately certain\n4: High - Confident with good evidence\n5: Very High - Highly confident, well-established",
